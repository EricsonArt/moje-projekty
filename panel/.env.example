# Vercel env vars - dodaj w Project Settings -> Environment Variables

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Permissions:
#   - Contents: Read and write (preferences.yaml, ratings.json)
#   - Actions: Read and write (workflow_dispatch)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth PIN dla panelu (4-6 cyfr)
PANEL_PIN=1234

# Token dla Telegram bot callback (rating endpoint)
# Wygeneruj random 32 znaki, ten sam ustaw w GitHub Secrets jako RATING_TOKEN
RATING_TOKEN=abc123randomstring

# Repo (defaultowo EricsonArt/moje-projekty)
GITHUB_OWNER=EricsonArt
GITHUB_REPO=moje-projekty
