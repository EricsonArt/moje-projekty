# Skopiuj ten plik do `.env` i uzupelnij realnymi kluczami.
# `.env` jest w .gitignore - nie wrzucasz tego do repo.
#
# Wszystkie klucze sa DARMOWE. SETUP.md ma krok po kroku gdzie je wziac.

# === LLM providers ===
# Google AI Studio - darmowe ~250-500 req/dzien na Gemini 2.5 Flash
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Console - darmowe ~30 RPM na Llama 3.3 70B
# https://console.groq.com/keys
GROQ_API_KEY=

# YouTube Data API v3 - darmowe 10k units/dzien
# https://console.cloud.google.com/apis/credentials (wlacz YT Data API v3)
# OPCJONALNE - jezeli pusty, system uzywa tylko swipe-file.txt
YOUTUBE_API_KEY=

# === Delivery ===
# Telegram bot - utworz przez @BotFather
TELEGRAM_BOT_TOKEN=
# Twoj chat_id - znajdziesz przez @userinfobot
TELEGRAM_CHAT_ID=

# === Settings ===
# Ilu skryptow generujemy dziennie (default 3)
SCRIPTS_PER_DAY=3

# Tryb debug - wiecej logow
DEBUG=false
